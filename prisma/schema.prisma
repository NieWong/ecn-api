datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
}

enum MembershipLevel {
  REGULAR_USER      // энгийн хэрэглэгч
  MEMBER            // Гишүүн
  HONORARY_MEMBER   // Хүндэт Гишүүн
  BOARD_MEMBER      // Удирдах зөвлөлийн Гишүүн
  ADMIN_MEMBER      // Admin
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NotificationType {
  ARTICLE_SUBMITTED      // When user submits article for review
  ARTICLE_APPROVED       // When admin approves article
  ARTICLE_REJECTED       // When admin rejects article
  ARTICLE_COMMENTED      // When admin comments on article
  MEMBERSHIP_CHANGED     // When admin changes user membership level
  USER_APPROVED          // When admin approves user registration
  SYSTEM                 // System notifications
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum FileKind {
  IMAGE
  DOCUMENT
  OTHER
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String?
  password String?
  role     Role    @default(USER)
  isActive Boolean @default(false)
  membershipLevel MembershipLevel @default(REGULAR_USER)

  // Profile fields
  profilePictureId String?
  profilePicture   File?   @relation("UserProfilePicture", fields: [profilePictureId], references: [id], onDelete: SetNull)
  profilePicturePath String? // Local path for profile picture stored in frontend
  
  cvFileId String?
  cvFile   File?   @relation("UserCV", fields: [cvFileId], references: [id], onDelete: SetNull)
  cvFilePath String? // Local path for CV stored in frontend
  
  aboutMe   String?
  facebook  String?
  twitter   String?
  linkedin  String?
  phone     String?
  website   String?

  posts Post[]
  files File[]
  notifications Notification[]
  approvedPosts Post[] @relation("PostApprovedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([isActive])
  @@index([membershipLevel])
}

model Post {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  summary     String?
  contentJson Json
  contentHtml String?
  status      PostStatus @default(DRAFT)
  visibility  Visibility @default(PUBLIC)
  
  // Approval workflow
  isApproved    Boolean   @default(false)
  approvedAt    DateTime?
  approvedById  String?
  approvedBy    User?     @relation("PostApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  adminComment  String?   // Admin can leave feedback for author

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  coverFileId String?
  coverFile   File?   @relation("PostCoverFile", fields: [coverFileId], references: [id], onDelete: SetNull)
  coverImagePath String? // Local path for cover image stored in frontend

  categories PostCategory[]
  images     PostImage[]

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([authorId])
  @@index([status])
  @@index([visibility])
  @@index([createdAt])
  @@index([isApproved])
}

model Category {
  id   String @id @default(uuid())
  name String
  slug String @unique

  posts PostCategory[]

  createdAt DateTime @default(now())

  @@index([name])
}

model PostCategory {
  postId     String
  categoryId String

  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@index([categoryId])
}

model File {
  id String @id @default(uuid())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  kind       FileKind   @default(OTHER)
  visibility Visibility @default(PUBLIC)

  originalName String
  mimeType     String
  size         Int
  storageKey   String @unique

  width  Int?
  height Int?

  postImages       PostImage[]
  coverFor         Post[]      @relation("PostCoverFile")
  userProfileFor   User[]      @relation("UserProfilePicture")
  userCVFor        User[]      @relation("UserCV")

  createdAt DateTime @default(now())

  @@index([ownerId])
  @@index([visibility])
  @@index([kind])
}

model PostImage {
  postId String
  fileId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  sort Int @default(0)

  @@id([postId, fileId])
  @@index([fileId])
}

model Notification {
  id          String           @id @default(uuid())
  type        NotificationType
  title       String
  message     String
  isRead      Boolean          @default(false)
  
  // Related entities (optional)
  postId      String?
  
  // Recipient
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Metadata (JSON for flexible additional data)
  metadata    Json?
  
  createdAt   DateTime         @default(now())
  
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
